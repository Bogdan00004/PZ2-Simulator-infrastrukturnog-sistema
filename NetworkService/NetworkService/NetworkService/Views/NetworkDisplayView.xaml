<UserControl x:Class="NetworkService.Views.NetworkDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             xmlns:model="clr-namespace:NetworkService.Model"
             Background="{StaticResource UIPrimaryColor}"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <DataTemplate x:Key="SlotTemplate">
            <Border Margin="3" CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"      Value="{StaticResource UISecondaryColor}"/>
                        <Setter Property="BorderBrush"     Value="{StaticResource UIBorderColor}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelectedForConnection}" Value="True">
                                <Setter Property="BorderBrush"     Value="{StaticResource UIAlertColor}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Entity.StatusText}" Value="VALID">
                                <Setter Property="BorderBrush"     Value="{StaticResource UISuccessColor}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Entity.StatusText}" Value="OUT OF RANGE">
                                <Setter Property="BorderBrush"     Value="{StaticResource UIDangerColor}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#1C0A0A"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <!-- OUT OF RANGE pulsing overlay animation -->
                    <Border CornerRadius="5" IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#C0392B"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Entity.StatusText}"
                                            Value="OUT OF RANGE">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="PulseAnim">
                                                <Storyboard RepeatBehavior="Forever"
                                                        AutoReverse="True">
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="0" To="0.2"
                                                           Duration="0:0:0.75"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseAnim"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- EMPTY STATE -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <fa:ImageAwesome Icon="PlusCircle"
                                         Foreground="{StaticResource UIBorderColor}"
                                         Width="22" Height="22"
                                         HorizontalAlignment="Center"
                                         Opacity="0.35"/>
                        <TextBlock Text="Drop here"
                                   FontSize="9"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource UIBorderColor}"
                                   Opacity="0.35"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- OCCUPIED STATE -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Remove button -->
                        <Button Grid.RowSpan="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Width="18" Height="18"
                                Padding="0"
                                Margin="0,3,3,0"
                                Panel.ZIndex="5"
                                Command="{Binding DataContext.ClearSlotCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip="Return entity to list">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"
                                                    Value="{StaticResource UIDangerColor}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <fa:ImageAwesome Icon="Times"
                                             Foreground="{StaticResource UIBorderColor}"
                                             Width="9" Height="9"/>
                        </Button>

                        <!-- Entity info with actual PNG image -->
                        <StackPanel Grid.Row="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="4,8,4,4">
                            <Image Source="{Binding Entity.Type.ImagePath}"
                                   Width="32" Height="32"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding Entity.Name}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="100"
                                       Foreground="{StaticResource UITextColor}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Bottom info bar (ID + last value) -->
                        <Border Grid.Row="1"
                                Background="{StaticResource UIPrimaryColor}"
                                CornerRadius="0,0,4,4"
                                Padding="6,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Entity.Id, StringFormat='#{0}'}"
                                           FontSize="9"
                                           Foreground="{StaticResource UIBorderColor}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Entity.ValueDisplay}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource UIBorderColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Entity.StatusText}"
                                                             Value="VALID">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UISuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Entity.StatusText}"
                                                             Value="OUT OF RANGE">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UIDangerColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="Sitemap"
                                     Foreground="{StaticResource UIAccentColor}"
                                     Width="16" Height="16"
                                     Margin="0,0,9,0"/>
                    <TextBlock Text="Network Display"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource UITextColor}"/>
                </StackPanel>
                <Button Grid.Column="1" Height="28"
                        Command="{Binding ToggleConnectModeCommand}"
                        ToolTip="Toggle connection mode — click two entities to connect them">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background" Value="{StaticResource UISecondaryColor}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource UIBorderColor}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnectModeActive}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource UIAlertColor}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" Margin="6,0">
                        <fa:ImageAwesome Icon="Link" Foreground="White"
                                         Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding ConnectModeButtonText}"
                                   Foreground="White" FontSize="11"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- TREE VIEW with PNG images -->
        <Border Grid.Row="1"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1"
                MaxHeight="210">
            <TreeView x:Name="EntitiesTreeView"
                      ItemsSource="{Binding TreeViewGroups}"
                      Background="{StaticResource UIPrimaryColor}"
                      BorderThickness="0"
                      SelectedItemChanged="TreeView_SelectedItemChanged"
                      MouseLeftButtonUp="TreeView_MouseLeftButtonUp"
                      PreviewMouseLeftButtonDown="TreeView_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="TreeView_PreviewMouseMove"
                      Padding="4">

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="Foreground" Value="{StaticResource UITextColor}"/>
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.Resources>
                    <!-- Group template with PNG image -->
                    <HierarchicalDataTemplate DataType="{x:Type model:PressureGaugeGroup}"
                                              ItemsSource="{Binding Entities}">
                        <StackPanel Orientation="Horizontal" Margin="2,3">
                            <Image Source="{Binding TypeImagePath}"
                                   Width="16" Height="16"
                                   Margin="0,0,7,0"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding TypeName}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Foreground="{StaticResource UITextColor}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Entity template with PNG image -->
                    <DataTemplate DataType="{x:Type model:PressureGauge}">
                        <StackPanel Orientation="Horizontal" Margin="2,2">
                            <Image Source="{Binding Type.ImagePath}"
                                   Width="14" Height="14"
                                   Margin="0,0,7,0"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="{StaticResource UITextColor}"/>
                            <TextBlock Text="{Binding Id, StringFormat=' #{0}'}"
                                       FontSize="11"
                                       Foreground="{StaticResource UIBorderColor}"/>
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>
        </Border>

        <!-- AUTO-PLACE TOOLBAR (CG1) -->
        <Border Grid.Row="2"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1"
                Padding="10,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           FontSize="11"
                           Foreground="{StaticResource UIBorderColor}"
                           VerticalAlignment="Center"
                           Text="Drag entities onto the grid, or use Auto-Place"/>
                <Button Grid.Column="1" Height="28"
                        Command="{Binding AutoPlaceCommand}"
                        ToolTip="Place all listed entities on free slots (CG1)">
                    <StackPanel Orientation="Horizontal" Margin="6,0">
                        <fa:ImageAwesome Icon="Magic" Foreground="White"
                                         Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Text="Auto-Place All" Foreground="White" FontSize="11"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- CANVAS GRID + LINES OVERLAY -->
        <Grid Grid.Row="3" x:Name="CanvasArea">
            <Canvas x:Name="LinesCanvas" IsHitTestVisible="False" Panel.ZIndex="10"/>

            <Grid x:Name="SlotsGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ContentControl Grid.Row="0" Grid.Column="0" Content="{Binding Slots[0]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="0" Grid.Column="1" Content="{Binding Slots[1]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="0" Grid.Column="2" Content="{Binding Slots[2]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="0" Grid.Column="3" Content="{Binding Slots[3]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

                <ContentControl Grid.Row="1" Grid.Column="0" Content="{Binding Slots[4]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding Slots[5]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding Slots[6]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="1" Grid.Column="3" Content="{Binding Slots[7]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

                <ContentControl Grid.Row="2" Grid.Column="0" Content="{Binding Slots[8]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="2" Grid.Column="1" Content="{Binding Slots[9]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="2" Grid.Column="2" Content="{Binding Slots[10]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                <ContentControl Grid.Row="2" Grid.Column="3" Content="{Binding Slots[11]}" ContentTemplate="{StaticResource SlotTemplate}" AllowDrop="True" Cursor="Hand" MouseMove="Slot_MouseMove" MouseLeftButtonDown="Slot_MouseLeftButtonDown" DragOver="Slot_DragOver" Drop="Slot_Drop" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>