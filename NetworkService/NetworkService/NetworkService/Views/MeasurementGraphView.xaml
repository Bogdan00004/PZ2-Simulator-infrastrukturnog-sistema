<UserControl x:Class="NetworkService.Views.MeasurementGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             Background="{StaticResource UIPrimaryColor}"
             Loaded="UserControl_Loaded">

    <!-- Fade-in animation on load -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="CircleThin"
                                     Foreground="{StaticResource UIAccentColor}"
                                     Width="17" Height="17"
                                     Margin="0,0,10,0"/>
                    <TextBlock Text="Measurement Graph"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource UITextColor}"/>
                    <TextBlock Text="  —  Last 5 Readings"
                               FontSize="12"
                               Foreground="{StaticResource UIBorderColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Legend -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="11" Height="11"
                             Fill="{StaticResource UISuccessColor}"
                             Margin="0,0,6,0"/>
                    <TextBlock Text="Valid (5 – 16 MPa)"
                               FontSize="11"
                               Foreground="{StaticResource UIBorderColor}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Ellipse Width="11" Height="11"
                             Fill="{StaticResource UIDangerColor}"
                             Margin="0,0,6,0"/>
                    <TextBlock Text="Out of range"
                               FontSize="11"
                               Foreground="{StaticResource UIBorderColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <fa:ImageAwesome Icon="Filter"
                                 Foreground="{StaticResource UIBorderColor}"
                                 Width="13" Height="13"
                                 Margin="0,0,10,0"/>
                <TextBlock Text="Select entity:"
                           FontSize="12"
                           Foreground="{StaticResource UIBorderColor}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <ComboBox Width="260" Height="32"
                          ItemsSource="{Binding Entities}"
                          SelectedItem="{Binding SelectedEntity}"
                          ToolTip="Select which entity's measurement history to display">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Type.ImagePath}"
                                       Width="18" Height="18"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource UITextColor}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Id, StringFormat=' (#{0})'}"
                                           Foreground="{StaticResource UIBorderColor}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Current value badge -->
                <Border Margin="20,0,0,0"
                        Background="{StaticResource UIPrimaryColor}"
                        BorderBrush="{StaticResource UIBorderColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Latest reading: "
                                   FontSize="12"
                                   Foreground="{StaticResource UIBorderColor}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedEntity.ValueDisplay}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock"
                                       BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource UIBorderColor}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedEntity.StatusText}"
                                                     Value="VALID">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource UISuccessColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedEntity.StatusText}"
                                                     Value="OUT OF RANGE">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource UIDangerColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- GRAPH AREA -->
        <Grid Grid.Row="2" Margin="20">
            <Border Background="{StaticResource UISecondaryColor}"
                    BorderBrush="{StaticResource UIBorderColor}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Canvas x:Name="GraphCanvas"
                            ClipToBounds="True"
                            SizeChanged="GraphCanvas_SizeChanged"/>

                    <StackPanel x:Name="NoDataPanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <fa:ImageAwesome Icon="LineChart"
                                         Foreground="{StaticResource UIBorderColor}"
                                         Width="40" Height="40"
                                         HorizontalAlignment="Center"
                                         Opacity="0.3"/>
                        <TextBlock Text="No measurements yet for this entity"
                                   FontSize="13"
                                   Foreground="{StaticResource UIBorderColor}"
                                   Opacity="0.6"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="Waiting for data from MeteringSimulator..."
                                   FontSize="11"
                                   Foreground="{StaticResource UIBorderColor}"
                                   Opacity="0.4"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>