<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             Background="{StaticResource UIPrimaryColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar (two cards) -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="48"/>
            <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="Database"
                                     Foreground="{StaticResource UIAccentColor}"
                                     Width="17" Height="17"
                                     Margin="0,0,10,0"/>
                    <TextBlock Text="Network Entities"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource UITextColor}"/>
                    <TextBlock Text="  —  Pressure Valve Monitoring"
                               FontSize="12"
                               Foreground="{StaticResource UIBorderColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="{StaticResource UIPrimaryColor}"
                        BorderBrush="{StaticResource UIBorderColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                      <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                           <fa:ImageAwesome Icon="Sliders"
                                Foreground="{StaticResource UIAccentColor}"
                                Width="12" Height="12"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                              <TextBlock Text="Valid range:"
                                    FontSize="11"
                                    Foreground="{StaticResource UIBorderColor}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,5,0"/>
                              <TextBlock Text="5 – 16 MPa"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource UITextColor}"
                                    VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== TOOLBAR: two panels ===== -->
        <Border Grid.Row="1"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ============ PANEL 1: ADD ENTITY ============ -->
                <Border Grid.Column="0"
                        Background="{StaticResource UIPrimaryColor}"
                        BorderBrush="{StaticResource UIBorderColor}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <fa:ImageAwesome Icon="PlusCircle"
                                             Foreground="{StaticResource UIAccentColor}"
                                             Width="13" Height="13"
                                             Margin="0,0,8,0"/>
                            <TextBlock Text="ADD NEW ENTITY"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource UIAccentColor}"/>
                        </StackPanel>

                        <TextBlock Text="Entity type"
                                   FontSize="11"
                                   Foreground="{StaticResource UIBorderColor}"
                                   Margin="0,0,0,5"/>

                        <ComboBox Height="34"
                                  ItemsSource="{Binding AvailableTypes}"
                                  SelectedItem="{Binding SelectedTypeToAdd}"
                                  ToolTip="Select entity type to add">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <fa:ImageAwesome Icon="{Binding Icon}"
                                                         Foreground="{Binding IconBrush}"
                                                         Width="15" Height="15"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource UITextColor}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Validation message -->
                        <TextBlock Text="{Binding TypeValidationError}"
                                   FontSize="11"
                                   Foreground="{StaticResource UIDangerColor}"
                                   Margin="2,5,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasTypeValidationError,
                                                Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <Button Height="34"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Stretch"
                                Command="{Binding AddCommand}"
                                ToolTip="Add new entity — ID and name are auto-generated (CG1)">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <fa:ImageAwesome Icon="PlusCircle"
                                                 Foreground="White"
                                                 Width="13" Height="13"
                                                 Margin="0,0,7,0"/>
                                <TextBlock Text="Add Entity" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="ID and name are generated automatically."
                                   FontSize="10"
                                   Foreground="{StaticResource UIBorderColor}"
                                   Opacity="0.7"
                                   Margin="2,8,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ============ PANEL 2: SEARCH & FILTER (P1) ============ -->
                <Border Grid.Column="2"
                        Background="{StaticResource UIPrimaryColor}"
                        BorderBrush="{StaticResource UIBorderColor}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <fa:ImageAwesome Icon="Search"
                                             Foreground="{StaticResource UIAccentColor}"
                                             Width="13" Height="13"
                                             Margin="0,0,8,0"/>
                            <TextBlock Text="SEARCH AND FILTER (P1)"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource UIAccentColor}"/>
                        </StackPanel>

                        <!-- Row 1: criteria + text -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                <TextBlock Text="Search by"
                                           FontSize="11"
                                           Foreground="{StaticResource UIBorderColor}"
                                           Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton Content="Name"
                                                 IsChecked="{Binding SearchByName}"
                                                 VerticalAlignment="Center"
                                                 ToolTip="Filter entities by name"/>
                                    <RadioButton Content="Type"
                                                 IsChecked="{Binding SearchByType}"
                                                 VerticalAlignment="Center"
                                                 ToolTip="Filter entities by type"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Vertical">
                                <TextBlock Text="Search term"
                                           FontSize="11"
                                           Foreground="{StaticResource UIBorderColor}"
                                           Margin="0,0,0,5"/>
                                <TextBox Height="34"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Type to filter entities in real-time"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: saved searches -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <fa:ImageAwesome Icon="Bookmark"
                                                     Foreground="{StaticResource UIBorderColor}"
                                                     Width="11" Height="11"
                                                     Margin="0,0,6,0"/>
                                    <TextBlock Text="Saved searches (CG1)"
                                               FontSize="11"
                                               Foreground="{StaticResource UIBorderColor}"/>
                                </StackPanel>
                                <ComboBox Height="34"
                                          ItemsSource="{Binding SavedSearches}"
                                          SelectedItem="{Binding SelectedSavedSearch}"
                                          IsEnabled="{Binding SavedSearches.Count,
                                                      Converter={StaticResource CountToBoolConverter}}"
                                          ToolTip="Select a saved search to load it"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Width="120" Height="34"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding SaveSearchCommand}"
                                    ToolTip="Save current search criteria for later use (CG1)">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <fa:ImageAwesome Icon="Download"
                                                     Foreground="White"
                                                     Width="12" Height="12"
                                                     Margin="0,0,6,0"/>
                                    <TextBlock Text="Save search" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4"
                                    Width="90" Height="34"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding ClearSearchCommand}"
                                    ToolTip="Clear search and show all entities">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <fa:ImageAwesome Icon="TimesCircle"
                                                     Foreground="White"
                                                     Width="12" Height="12"
                                                     Margin="0,0,6,0"/>
                                    <TextBlock Text="Clear" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ===== DATA GRID ===== -->
        <DataGrid Grid.Row="2"
                  Margin="16,12,16,12"
                  ItemsSource="{Binding EntitiesView}"
                  SelectedItem="{Binding SelectedEntity}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="{StaticResource UIBorderColor}"
                  RowHeight="42">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="60"/>

                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <!-- Type with FontAwesome icon -->
                <DataGridTemplateColumn Header="Type" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8,0">
                                <fa:ImageAwesome Icon="{Binding Type.Icon}"
                                                 Foreground="{Binding Type.IconBrush}"
                                                 Width="15" Height="15"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TypeName}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Last measured value -->
                <DataGridTemplateColumn Header="Last Value" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ValueDisplay}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource UIBorderColor}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}"
                                                         Value="VALID">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource UISuccessColor}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}"
                                                         Value="OUT OF RANGE">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource UIDangerColor}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status with icon -->
                <DataGridTemplateColumn Header="Status" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <fa:ImageAwesome Width="14" Height="14" Margin="0,0,6,0">
                                    <fa:ImageAwesome.Style>
                                        <Style TargetType="fa:ImageAwesome">
                                            <Setter Property="Icon"      Value="MinusCircle"/>
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource UIBorderColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}"
                                                             Value="VALID">
                                                    <Setter Property="Icon"
                                                            Value="CheckCircle"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UISuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}"
                                                             Value="OUT OF RANGE">
                                                    <Setter Property="Icon"
                                                            Value="ExclamationTriangle"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UIDangerColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </fa:ImageAwesome.Style>
                                </fa:ImageAwesome>
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="12"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource UIBorderColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}"
                                                             Value="VALID">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UISuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}"
                                                             Value="OUT OF RANGE">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UIDangerColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ===== BOTTOM BAR ===== -->
        <Border Grid.Row="3"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="InfoCircle"
                                     Foreground="{StaticResource UIBorderColor}"
                                     Width="13" Height="13"
                                     Margin="0,0,7,0"/>
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource UIBorderColor}"
                               Text="Select a row from the table, then click Delete to remove an entity."/>
                </StackPanel>

                <Button Grid.Column="1"
                        Height="34"
                        Command="{Binding DeleteCommand}"
                        ToolTip="Delete selected entity — confirmation required">
                    <Button.Style>
                        <Style TargetType="Button"
                               BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background"
                                    Value="{StaticResource UIDangerColor}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#A93226"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" Margin="6,0">
                        <fa:ImageAwesome Icon="Trash"
                                         Foreground="White"
                                         Width="14" Height="14"
                                         Margin="0,0,7,0"/>
                        <TextBlock Text="Delete Selected" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>