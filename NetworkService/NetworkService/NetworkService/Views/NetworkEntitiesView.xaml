<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource UIPrimaryColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="16,0">
                <TextBlock Text="⊞"
                           FontSize="20"
                           Foreground="{StaticResource UIAccentColor}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBlock Text="NETWORK ENTITIES"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource UITextColor}"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" — Pressure Monitoring"
                           FontSize="12"
                           Foreground="{StaticResource UIBorderColor}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ACTION BAR -->
        <Border Grid.Row="1"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ADD ENTITY (CG1: type only) -->
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="ADD NEW ENTITY"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource UIAccentColor}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="200"
                                  Height="32"
                                  ItemsSource="{Binding AvailableTypes}"
                                  SelectedItem="{Binding SelectedTypeToAdd}"
                                  ToolTip="Select the type of pressure gauge to add">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding ImagePath}"
                                               Width="18" Height="18"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="+ ADD ENTITY"
                                Width="130" Height="32"
                                Margin="8,0,0,0"
                                Command="{Binding AddCommand}"
                                ToolTip="Add a new entity with auto-generated ID and name"/>
                    </StackPanel>
                </StackPanel>

                <!-- Vertical separator -->
                <Rectangle Grid.Column="1"
                           Width="1"
                           Fill="{StaticResource UIBorderColor}"
                           HorizontalAlignment="Center"/>

                <!-- SEARCH AND FILTER (P1) -->
                <StackPanel Grid.Column="2"
                            Orientation="Vertical"
                            Margin="8,0,0,0">
                    <TextBlock Text="SEARCH AND FILTER (P1)"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource UIAccentColor}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="By Name"
                                     IsChecked="{Binding SearchByName}"
                                     VerticalAlignment="Center"
                                     ToolTip="Search by entity name"/>
                        <RadioButton Content="By Type"
                                     IsChecked="{Binding SearchByType}"
                                     VerticalAlignment="Center"
                                     ToolTip="Search by entity type"/>
                        <TextBox Width="180" Height="32"
                                 Margin="8,0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type to filter entities in real-time"/>
                        <ComboBox Width="180" Height="32"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding SavedSearches}"
                                  SelectedItem="{Binding SelectedSavedSearch}"
                                  IsEnabled="{Binding SavedSearches.Count, Converter={StaticResource CountToBoolConverter}}"
                                  ToolTip="Select a saved search to reload it"/>
                        <Button Content="Save"
                                Width="80" Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding SaveSearchCommand}"
                                ToolTip="Save current search criteria for later use"/>
                        <Button Content="Clear"
                                Width="80" Height="32"
                                Command="{Binding ClearSearchCommand}"
                                ToolTip="Clear search and show all entities"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DATA GRID -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding EntitiesView}"
                  SelectedItem="{Binding SelectedEntity}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="60"/>

                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="160"/>

                <!-- Type with image -->
                <DataGridTemplateColumn Header="Type" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="6,0">
                                <Image Source="{Binding Type.ImagePath}"
                                       Width="18" Height="18"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TypeName}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Last Value with color -->
                <DataGridTemplateColumn Header="Last Value" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ValueDisplay}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource UIBorderColor}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValueValid}" Value="True">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource UISuccessColor}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Valid Range (hardcoded for T1) -->
                <DataGridTemplateColumn Header="Valid Range" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="5 - 16 MPa"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource UIBorderColor}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status badge -->
                <DataGridTemplateColumn Header="Status" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4"
                                    Padding="8,3"
                                    HorizontalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{StaticResource UIBorderColor}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="VALID">
                                                <Setter Property="Background"
                                                        Value="{StaticResource UISuccessColor}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="OUT OF RANGE">
                                                <Setter Property="Background"
                                                        Value="{StaticResource UIDangerColor}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- BOTTOM BAR -->
        <Border Grid.Row="3"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{StaticResource UIBorderColor}">
                    <Run Text="Select an entity from the table, then click Delete.   "/>
                    <Run Text="Valid pressure range: 5 - 16 MPa"
                         Foreground="{StaticResource UIAccentColor}"/>
                </TextBlock>

                <Button Grid.Column="1"
                        Content="DELETE SELECTED"
                        Width="160" Height="34"
                        Command="{Binding DeleteCommand}"
                        ToolTip="Delete the selected entity (confirmation required)">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background" Value="{StaticResource UIDangerColor}"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

    </Grid>
</UserControl>