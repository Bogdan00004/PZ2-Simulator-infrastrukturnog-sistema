<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             Background="{StaticResource UIPrimaryColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="48"/>
            <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="Database"
                                     Foreground="{StaticResource UIAccentColor}"
                                     Width="17" Height="17"
                                     Margin="0,0,10,0"/>
                    <TextBlock Text="Network Entities"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource UITextColor}"/>
                    <TextBlock Text="  —  Pressure Valve Monitoring"
                               FontSize="12"
                               Foreground="{StaticResource UIBorderColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource UIPrimaryColor}"
                        BorderBrush="{StaticResource UIBorderColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Sliders"
                                         Foreground="{StaticResource UIBorderColor}"
                                         Width="12" Height="12"
                                         Margin="0,0,7,0"/>
                        <TextBlock Text="Valid range: 5 — 16 MPa"
                                   FontSize="11"
                                   Foreground="{StaticResource UIBorderColor}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== TOOLBAR (two rows) ===== -->
        <Border Grid.Row="1"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 1: Add entity + Search input -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Add section -->
                        <ColumnDefinition Width="20"/>
                        <!-- Gap -->
                        <ColumnDefinition Width="1"/>
                        <!-- Separator -->
                        <ColumnDefinition Width="20"/>
                        <!-- Gap -->
                        <ColumnDefinition Width="*"/>
                        <!-- Search section -->
                    </Grid.ColumnDefinitions>

                    <!-- Add entity (CG1: type only) -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ComboBox Width="195" Height="32"
                                  ItemsSource="{Binding AvailableTypes}"
                                  SelectedItem="{Binding SelectedTypeToAdd}"
                                  ToolTip="Select entity type to add">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <fa:ImageAwesome Icon="{Binding Icon}"
                                                         Foreground="{Binding IconBrush}"
                                                         Width="15" Height="15"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Height="32" Margin="8,0,0,0"
                                Command="{Binding AddCommand}"
                                ToolTip="Add new entity — ID and name are auto-generated (CG1)">
                            <StackPanel Orientation="Horizontal" Margin="4,0">
                                <fa:ImageAwesome Icon="PlusCircle"
                                                 Foreground="White"
                                                 Width="13" Height="13"
                                                 Margin="0,0,6,0"/>
                                <TextBlock Text="Add Entity" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Vertical separator -->
                    <Rectangle Grid.Column="2"
                               Fill="{StaticResource UIBorderColor}"/>

                    <!-- Search (P1) -->
                    <StackPanel Grid.Column="4"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <fa:ImageAwesome Icon="Search"
                                         Foreground="{StaticResource UIBorderColor}"
                                         Width="13" Height="13"
                                         Margin="0,0,10,0"/>
                        <RadioButton Content="By Name"
                                     IsChecked="{Binding SearchByName}"
                                     VerticalAlignment="Center"
                                     ToolTip="Filter entities by name"/>
                        <RadioButton Content="By Type"
                                     IsChecked="{Binding SearchByType}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,12,0"
                                     ToolTip="Filter entities by type"/>
                        <TextBox Width="220" Height="32"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type to filter entities in real-time"/>
                    </StackPanel>
                </Grid>

                <!-- ROW 2: Saved searches (CG1) -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Label -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <fa:ImageAwesome Icon="Bookmark"
                                         Foreground="{StaticResource UIBorderColor}"
                                         Width="12" Height="12"
                                         Margin="0,0,7,0"/>
                        <TextBlock Text="Saved searches:"
                                   FontSize="11"
                                   Foreground="{StaticResource UIBorderColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Saved searches ComboBox -->
                    <ComboBox Grid.Column="1"
                              Height="30"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding SavedSearches}"
                              SelectedItem="{Binding SelectedSavedSearch}"
                              IsEnabled="{Binding SavedSearches.Count,
                                          Converter={StaticResource CountToBoolConverter}}"
                              ToolTip="Select a saved search to load it (CG1)"/>

                    <!-- Save + Clear buttons -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal">
                        <Button Height="30"
                                Margin="0,0,6,0"
                                Command="{Binding SaveSearchCommand}"
                                ToolTip="Save current search criteria for later use (CG1)">
                            <StackPanel Orientation="Horizontal" Margin="6,0">
                                <fa:ImageAwesome Icon="Download"
                                                 Foreground="White"
                                                 Width="12" Height="12"
                                                 Margin="0,0,6,0"/>
                                <TextBlock Text="Save search" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Button>

                        <Button Height="30"
                                Command="{Binding ClearSearchCommand}"
                                ToolTip="Clear search and show all entities">
                            <StackPanel Orientation="Horizontal" Margin="6,0">
                                <fa:ImageAwesome Icon="TimesCircle"
                                                 Foreground="White"
                                                 Width="12" Height="12"
                                                 Margin="0,0,6,0"/>
                                <TextBlock Text="Clear" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ===== DATA GRID ===== -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding EntitiesView}"
                  SelectedItem="{Binding SelectedEntity}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  RowHeight="40">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="60"/>

                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <!-- Type with FontAwesome icon -->
                <DataGridTemplateColumn Header="Type" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8,0">
                                <fa:ImageAwesome Icon="{Binding Type.Icon}"
                                                 Foreground="{Binding Type.IconBrush}"
                                                 Width="15" Height="15"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TypeName}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Last measured value -->
                <DataGridTemplateColumn Header="Last Value" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ValueDisplay}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource UIBorderColor}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}"
                                                         Value="VALID">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource UISuccessColor}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}"
                                                         Value="OUT OF RANGE">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource UIDangerColor}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status with icon -->
                <DataGridTemplateColumn Header="Status" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <fa:ImageAwesome Width="14" Height="14" Margin="0,0,6,0">
                                    <fa:ImageAwesome.Style>
                                        <Style TargetType="fa:ImageAwesome">
                                            <Setter Property="Icon"      Value="MinusCircle"/>
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource UIBorderColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}"
                                                             Value="VALID">
                                                    <Setter Property="Icon"
                                                            Value="CheckCircle"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UISuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}"
                                                             Value="OUT OF RANGE">
                                                    <Setter Property="Icon"
                                                            Value="ExclamationTriangle"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UIDangerColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </fa:ImageAwesome.Style>
                                </fa:ImageAwesome>
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="12"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource UIBorderColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}"
                                                             Value="VALID">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UISuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}"
                                                             Value="OUT OF RANGE">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource UIDangerColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ===== BOTTOM BAR ===== -->
        <Border Grid.Row="3"
                Background="{StaticResource UISecondaryColor}"
                BorderBrush="{StaticResource UIBorderColor}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="InfoCircle"
                                     Foreground="{StaticResource UIBorderColor}"
                                     Width="13" Height="13"
                                     Margin="0,0,7,0"/>
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource UIBorderColor}"
                               Text="Select a row from the table, then click Delete to remove an entity."/>
                </StackPanel>

                <Button Grid.Column="1"
                        Height="34"
                        Command="{Binding DeleteCommand}"
                        ToolTip="Delete selected entity — confirmation required">
                    <Button.Style>
                        <Style TargetType="Button"
                               BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background"
                                    Value="{StaticResource UIDangerColor}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#A93226"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" Margin="6,0">
                        <fa:ImageAwesome Icon="Trash"
                                         Foreground="White"
                                         Width="14" Height="14"
                                         Margin="0,0,7,0"/>
                        <TextBlock Text="Delete Selected" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

    </Grid>
</UserControl>